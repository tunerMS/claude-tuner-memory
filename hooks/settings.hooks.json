{
  "_comment": "Слей этот блок hooks в свой ~/.claude/settings.json. PreToolUse/PostToolUse кормят continuous-learning (захват наблюдений) и лог тест-прогонов, SessionStart вливает выученные инстинкты и session-memory прошлой работы обратно в сессию. Если у тебя уже есть hooks — добавь элементы в существующие массивы, не затирай.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "~/.claude/homunculus/capture-guard.sh pre" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "~/.claude/homunculus/capture-guard.sh post" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/testrun-capture.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "~/.claude/homunculus/recall-instincts.sh" }
        ]
      },
      {
        "matcher": "startup|clear",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/session-context.sh" }
        ]
      }
    ]
  }
}
