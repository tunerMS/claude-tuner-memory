# Денилист continuous-learning: НЕ наблюдать за этими директориями
# (захват логирует inputs/outputs инструментов — не давай ему видеть рабочие
# репозитории с кредами/токенами/секретами).
#
# По одному абсолютному префиксу cwd в строке. Срабатывает на сам путь и всё
# под ним. Скопируй в exclude_paths и правь под себя.

# Примеры (замени на свои):
# /Users/you/work/secret-client-repo
# /Users/you/company-monorepo
# ~/.ssh
